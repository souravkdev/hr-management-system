# ──────────────────────────────────────────
# HRMS Lite – Monorepo .gitignore
# ──────────────────────────────────────────

# ── Database ──────────────────────────────
db/*.db
db/*.sqlite3

# ── Backend (Python / FastAPI) ─────────────
backend/__pycache__/
backend/**/__pycache__/
backend/*.pyc
backend/*.pyo
backend/.pytest_cache/
backend/venv/
backend/.env
backend/.env.*

# ── Frontend (Next.js) ────────────────────
frontend/.next/
frontend/out/
frontend/node_modules/
frontend/.env
frontend/.env.*
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# ── OS / Editor ───────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ── Docker ────────────────────────────────
*.log
